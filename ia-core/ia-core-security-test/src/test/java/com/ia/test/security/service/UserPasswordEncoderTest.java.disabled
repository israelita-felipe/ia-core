package com.ia.test.security.service;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.ParameterizedTest;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.junit.jupiter.params.provider.ValueSource;
import org.mockito.junit.jupiter.MockitoExtension;

import com.ia.core.security.service.model.user.UserPasswordEncoder;

/**
 * Testes unitários para {@link UserPasswordEncoder}.
 * Valida funcionalidades de codificação e decodificação de senhas.
 *
 * @author Israel Araújo
 */
@ExtendWith(MockitoExtension.class)
@DisplayName("UserPasswordEncoder")
class UserPasswordEncoderTest {

  private UserPasswordEncoder encoder;

  @BeforeEach
  void setUp() {
    encoder = UserPasswordEncoder.getInstance();
  }

  @Nested
  @DisplayName("encode")
  class EncodeTests {

    @Test
    @DisplayName("Deve codificar senha com sucesso")
    void shouldEncodePasswordSuccessfully() {
      // Dado
      String plainPassword = "MyPassword123!@#";

      // Quando
      String encodedPassword = encoder.encode(plainPassword);

      // Então
      assertThat(encodedPassword).isNotNull();
      assertThat(encodedPassword).isNotEqualTo(plainPassword);
      assertThat(encodedPassword).isNotBlank();
    }

    @Test
    @DisplayName("Deve gerar diferentes hashes para mesma senha")
    void shouldGenerateDifferentHashesForSamePassword() {
      // Dado
      String password = "MyPassword123!@#";

      // Quando
      String encoded1 = encoder.encode(password);
      String encoded2 = encoder.encode(password);

      // Então
      assertThat(encoded1).isNotEqualTo(encoded2);
    }

    @ParameterizedTest
    @ValueSource(strings = { "short", "MediumPassword", "VeryLongPasswordWithManyCharactersAndSymbols!@#$%^&*()" })
    @DisplayName("Deve codificar senhas de diferentes tamanhos")
    void shouldEncodePasswordsOfDifferentLengths(String password) {
      // Quando
      String encoded = encoder.encode(password);

      // Então
      assertThat(encoded).isNotNull();
      assertThat(encoded).isNotBlank();
    }
  }

  @Nested
  @DisplayName("verify")
  class VerifyTests {

    @Test
    @DisplayName("Deve verificar senha correta")
    void shouldVerifyCorrectPassword() {
      // Dado
      String plainPassword = "MyPassword123!@#";
      String encodedPassword = encoder.encode(plainPassword);

      // Quando
      boolean isValid = encoder.verify(plainPassword, encodedPassword);

      // Então
      assertThat(isValid).isTrue();
    }

    @Test
    @DisplayName("Deve rejeitar senha incorreta")
    void shouldRejectIncorrectPassword() {
      // Dado
      String plainPassword = "MyPassword123!@#";
      String wrongPassword = "WrongPassword456";
      String encodedPassword = encoder.encode(plainPassword);

      // Quando
      boolean isValid = encoder.verify(wrongPassword, encodedPassword);

      // Então
      assertThat(isValid).isFalse();
    }

    @Test
    @DisplayName("Deve rejeitar quando senha codificada é nula")
    void shouldRejectWhenEncodedPasswordIsNull() {
      // Dado
      String plainPassword = "MyPassword123!@#";

      // Quando & Então
      assertThatThrownBy(() -> encoder.verify(plainPassword, null))
          .isInstanceOf(NullPointerException.class);
    }

    @Test
    @DisplayName("Deve rejeitar quando senha simples é nula")
    void shouldRejectWhenPlainPasswordIsNull() {
      // Dado
      String encoded = encoder.encode("Password123");

      // Quando & Então
      assertThatThrownBy(() -> encoder.verify(null, encoded))
          .isInstanceOf(NullPointerException.class);
    }
  }

  @Nested
  @DisplayName("generateRandomPassword")
  class GenerateRandomPasswordTests {

    @Test
    @DisplayName("Deve gerar senha aleatória válida")
    void shouldGenerateValidRandomPassword() {
      // Quando
      String password = encoder.generateRandomPassword();

      // Então
      assertThat(password).isNotNull();
      assertThat(password).isNotBlank();
      assertThat(password.length()).isGreaterThan(0);
    }

    @Test
    @DisplayName("Deve gerar senhas diferentes em chamadas sucessivas")
    void shouldGenerateDifferentPasswordsInSuccessiveCalls() {
      // Quando
      String password1 = encoder.generateRandomPassword();
      String password2 = encoder.generateRandomPassword();
      String password3 = encoder.generateRandomPassword();

      // Então
      assertThat(password1).isNotEqualTo(password2);
      assertThat(password2).isNotEqualTo(password3);
      assertThat(password1).isNotEqualTo(password3);
    }

    @Test
    @DisplayName("Deve conter caracteres maiúsculos")
    void shouldContainUppercaseCharacters() {
      // Quando
      String password = encoder.generateRandomPassword();

      // Então
      boolean hasUppercase = password.chars()
          .anyMatch(Character::isUpperCase);
      assertThat(hasUppercase).isTrue();
    }

    @Test
    @DisplayName("Deve conter caracteres minúsculos")
    void shouldContainLowercaseCharacters() {
      // Quando
      String password = encoder.generateRandomPassword();

      // Então
      boolean hasLowercase = password.chars()
          .anyMatch(Character::isLowerCase);
      assertThat(hasLowercase).isTrue();
    }

    @Test
    @DisplayName("Deve conter caracteres especiais")
    void shouldContainSpecialCharacters() {
      // Quando
      String password = encoder.generateRandomPassword();

      // Então
      boolean hasSpecial = password.chars()
          .anyMatch(ch -> !Character.isLetterOrDigit(ch));
      assertThat(hasSpecial).isTrue();
    }
  }

  @Nested
  @DisplayName("isValid")
  class IsValidTests {

    @Test
    @DisplayName("Deve aceitar senha válida")
    void shouldAcceptValidPassword() {
      // Dado
      String validPassword = "MyPassword123!@#";

      // Quando
      boolean isValid = encoder.isValid(validPassword);

      // Então
      assertThat(isValid).isTrue();
    }

    @ParameterizedTest
    @ValueSource(strings = { "", "   ", "short", "123456" })
    @DisplayName("Deve rejeitar senhas fracas")
    void shouldRejectWeakPasswords(String weakPassword) {
      // Quando
      boolean isValid = encoder.isValid(weakPassword);

      // Então
      assertThat(isValid).isFalse();
    }

    @Test
    @DisplayName("Deve rejeitar senha nula")
    void shouldRejectNullPassword() {
      // Quando & Então
      assertThatThrownBy(() -> encoder.isValid(null))
          .isInstanceOf(NullPointerException.class);
    }
  }

  @Nested
  @DisplayName("getInstance")
  class GetInstanceTests {

    @Test
    @DisplayName("Deve retornar instância de UserPasswordEncoder")
    void shouldReturnInstanceOfUserPasswordEncoder() {
      // Quando
      UserPasswordEncoder instance = UserPasswordEncoder.getInstance();

      // Então
      assertThat(instance).isNotNull();
    }

    @Test
    @DisplayName("Deve retornar mesma instância em chamadas sucessivas")
    void shouldReturnSameInstanceInSuccessiveCalls() {
      // Quando
      UserPasswordEncoder instance1 = UserPasswordEncoder.getInstance();
      UserPasswordEncoder instance2 = UserPasswordEncoder.getInstance();

      // Então
      assertThat(instance1).isSameAs(instance2);
    }
  }
}
